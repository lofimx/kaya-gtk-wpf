{
  "id": "ca.deobald.Kaya",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.node24",
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.typescript"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/node24/bin:/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/typescript/bin"
  },
  "command": "ca.deobald.Kaya",
  "finish-args": [
    "--share=ipc",
    "--share=network",
    "--device=dri",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--filesystem=~/.kaya:create",
    "--filesystem=xdg-download:ro",
    "--filesystem=xdg-pictures:ro",
    "--filesystem=xdg-documents:ro",
    "--filesystem=home:ro",
    "--talk-name=org.freedesktop.secrets",
    "--talk-name=org.freedesktop.portal.Desktop",
    "--env=GI_TYPELIB_PATH=$GI_TYPELIB_PATH:/app/lib64/girepository-1.0:/app/lib/girepository-1.0",
    "--env=LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/app/lib64:/app/lib"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "kaya",
      "buildsystem": "meson",
      "build-options": {
        "env": {
          "npm_config_offline": "true",
          "npm_config_cache": "/run/build/kaya/flatpak-node/npm-cache"
        }
      },
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/steven/kaya-gnome.git",
          "branch": "v0.1.14",
          "commit": "0b84cac4d705d22ba10932cc2103a36f7798e52c"
        },
        "generated-sources.json"
      ]
    }
  ]
}
